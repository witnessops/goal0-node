{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.vaultsovereign.local/codex_policy_verdict.v1.json",
  "title": "VaultSovereign Codex Policy Verdict v1",
  "type": "object",
  "required": [
    "schema",
    "task_id",
    "decision",
    "checked_at",
    "checks",
    "task_hash"
  ],
  "properties": {
    "schema": {
      "const": "vaultsovereign.codex.policy_verdict.v1"
    },
    "task_id": {
      "type": "string"
    },
    "decision": {
      "enum": [
        "allow",
        "deny"
      ]
    },
    "checks": {
      "type": "array"
    },
    "task_hash": {
      "type": "string"
    }
  }
}
