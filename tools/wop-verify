#!/usr/bin/env python3
from __future__ import annotations

import argparse
import base64
import hashlib
import json
import sys
from pathlib import Path

TOOLS_DIR = Path(__file__).resolve().parent
sys.path.insert(0, str(TOOLS_DIR))

from wop_lib import load_ed25519_public_key, signing_payload_bytes  # noqa: E402


def main() -> int:
    parser = argparse.ArgumentParser(description="Verify an Ed25519 signature on a WitnessOps receipt.")
    parser.add_argument("--public-key", type=Path, default=None)
    parser.add_argument("receipt", type=Path)
    args = parser.parse_args()

    try:
        receipt_obj = json.loads(args.receipt.read_text(encoding="utf-8"))
    except (OSError, json.JSONDecodeError) as exc:
        print(f"VERIFY\tFAIL\t{exc}")
        return 1

    signature = receipt_obj.get("signature", {})
    if not isinstance(signature, dict) or signature.get("algorithm") != "ed25519":
        print("VERIFY\tUNSIGNED\tno_ed25519_signature")
        return 2

    public_key_path = args.public_key
    if public_key_path is None:
        raw_path = signature.get("public_key_path")
        if not raw_path:
            print("VERIFY\tFAIL\tmissing_public_key_path")
            return 1
        public_key_path = Path(raw_path)

    try:
        from nacl.exceptions import BadSignatureError

        payload = signing_payload_bytes(receipt_obj)
        verify_key = load_ed25519_public_key(public_key_path)
        sig = base64.b64decode(signature["signature"])
        verify_key.verify(payload, sig)
        observed_hash = "sha256:" + hashlib.sha256(payload).hexdigest()
        expected_hash = signature.get("signed_payload_hash", "")
        if expected_hash and expected_hash != observed_hash:
            print(f"VERIFY\tFAIL\thash_mismatch observed={observed_hash} expected={expected_hash}")
            return 1
        print(f"VERIFY\tPASS\t{args.receipt}")
        return 0
    except BadSignatureError:
        print("VERIFY\tFAIL\tbad_signature")
        return 1
    except Exception as exc:  # noqa: BLE001
        print(f"VERIFY\tFAIL\t{exc}")
        return 1


if __name__ == "__main__":
    raise SystemExit(main())