#!/usr/bin/env python3
from __future__ import annotations

import argparse
import hashlib
import sys
from pathlib import Path


def sha256_file(path: Path) -> str:
    return hashlib.sha256(path.read_bytes()).hexdigest()


def iter_files(path: Path) -> list[Path]:
    if path.is_file():
        return [path]
    if path.is_dir():
        return sorted(p for p in path.rglob("*") if p.is_file())
    raise FileNotFoundError(path)


def display_path(path: Path, relative_to: Path | None) -> str:
    if relative_to is None:
        return str(path)
    try:
        return str(path.relative_to(relative_to))
    except ValueError:
        return str(path)


def main() -> int:
    parser = argparse.ArgumentParser(description="Emit sha256 manifests for WitnessOps artifacts.")
    parser.add_argument("--format", choices=("tsv", "sha256sum"), default="tsv")
    parser.add_argument("--relative-to", type=Path, default=None)
    parser.add_argument("paths", nargs="+", type=Path)
    args = parser.parse_args()

    missing = False
    lines: list[str] = []
    for raw in args.paths:
        try:
            for file_path in iter_files(raw):
                digest = sha256_file(file_path)
                shown = display_path(file_path, args.relative_to)
                if args.format == "tsv":
                    lines.append(f"{shown}\t{digest}")
                else:
                    lines.append(f"{digest}  {shown}")
        except FileNotFoundError:
            print(f"MISSING\t{raw}", file=sys.stderr)
            missing = True

    for line in lines:
        print(line)

    if missing:
        return 2
    return 0


if __name__ == "__main__":
    raise SystemExit(main())