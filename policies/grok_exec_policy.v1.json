{
  "schema": "vaultsovereign.grok.exec_policy.v1",
  "policy_version": "grok_exec_policy.v1",
  "allowed_output_formats": [
    "json",
    "plain",
    "streaming-json"
  ],
  "allowed_sandboxes": [
    "strict",
    "normal"
  ],
  "deny_flags": [
    "--yolo",
    "--always-approve"
  ],
  "deny_tools": [
    "Agent"
  ],
  "allowed_read_only_tools": [
    "read_file",
    "grep",
    "list_dir"
  ],
  "denied_write_tools": [
    "run_terminal_cmd",
    "search_replace",
    "write",
    "delete_file",
    "web_search",
    "web_fetch"
  ],
  "allow_web_search_default": false,
  "require_operator_approval": true,
  "require_target_repo_exists": true,
  "require_expected_root_markers": true,
  "require_json_output": true,
  "redact_output_secrets": true,
  "max_prompt_chars": 12000,
  "max_turns_cap": 25,
  "secret_patterns": [
    "sk-[A-Za-z0-9_-]{20,}",
    "xai-[A-Za-z0-9_-]{20,}",
    "ghp_[A-Za-z0-9_]{20,}",
    "github_pat_[A-Za-z0-9_]{20,}",
    "xox[baprs]-[A-Za-z0-9-]{10,}",
    "AKIA[0-9A-Z]{16}",
    "-----BEGIN [A-Z ]*PRIVATE KEY-----"
  ],
  "notes": [
    "Use strict sandbox and disallowed shell tools for audit/summarization tasks.",
    "Use normal sandbox only for explicit workspace-write tasks with narrowed tool deny lists.",
    "Never pass --yolo or --always-approve through governed task bundles."
  ]
}